# ── Frontend (artifacts/daddyx) ──────────────────────────────────────────────
# Port for the Vite dev server. Defaults to 5173 when unset.
PORT=5173

# URL base path for the frontend. Defaults to / when unset.
BASE_PATH=/

# ── API Server (artifacts/api-server) ────────────────────────────────────────
# Port for the Express API server. Defaults to 3001 when unset.
# API_PORT=3001

# PostgreSQL connection string (required by the API server and DB library).
DATABASE_URL=postgresql://postgres:password@localhost:5432/daddyx

# Minimum log level: trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
